# === Base de données PostgreSQL ===
POSTGRES_USER=meetspace
POSTGRES_PASSWORD=change_me
POSTGRES_DB=meetspace

# === Connexion du back-end à la base (Prisma) ===
# Via docker-compose, l'hôte est le NOM du service : "db" (et non localhost).
DATABASE_URL=postgresql://meetspace:change_me@db:5432/meetspace

# === Sécurité ===
# Secret de signature des jetons JWT : remplacer par une longue valeur aléatoire.
JWT_SECRET=change_me_with_a_long_random_secret

# === CORS ===
# Origine autorisée à appeler l'API (URL du front-end).
CORS_ORIGIN=http://localhost:5173
